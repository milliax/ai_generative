# 預設 provider — Gemini Flash 免費版（每天 1500 次請求免費）
LLM_MODEL=gemini/gemini-1.5-flash
GEMINI_API_KEY=

# 替代 provider — 取消註解你要用的那組
# LLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=

# LLM_MODEL=anthropic/claude-haiku-4-5
# ANTHROPIC_API_KEY=

# LLM_MODEL=ollama/llama3.2          # 本地模型
# OLLAMA_API_BASE=http://localhost:11434

# 其他
LOG_LEVEL=INFO
CHROMA_PERSIST_DIR=./chroma_db
